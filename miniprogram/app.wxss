/* app.wxss */
/* 全局样式 */
page {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background-color: #f5f5f5;
    color: #333;
    line-height: 1.5;
  }
  
  .container {
    padding: 20rpx;
  }
  
  /* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  padding: 27rpx;
  margin: 20rpx auto;
  background-color: #4CAF50;
  color: white;
  text-align: center;
  border-radius: 20rpx;
  font-size: 29rpx;
  font-weight: bold;
  box-sizing: border-box;
}
  
  .btn:hover {
    background-color: #45a049;
  }
  
  /* 卡片样式 */
  .card {
    background-color: white;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  }
  
  /* 标题样式 */
  .title {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
    color: #333;
  }
  
  /* 副标题样式 */
  .subtitle {
    font-size: 28rpx;
    font-weight: bold;
    margin: 20rpx 0 10rpx 0;
    color: #555;
  }
  
  /* 文本样式 */
  .text {
    font-size: 26rpx;
    color: #666;
    line-height: 1.6;
  }
  
  /* 图片样式 */
  .image {
    width: 100%;
    border-radius: 10rpx;
    margin: 20rpx 0;
  }
  
  /* 加载动画 */
  .loading {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40rpx;
  }
  
  /* 结果页面样式 */
  .result-container {
    padding: 30rpx;
  }
  
  .disease-name {
    font-size: 36rpx;
    font-weight: bold;
    color: #d32f2f;
    margin-bottom: 20rpx;
  }
  
  .suggestion {
    margin-top: 30rpx;
  }
  
  .medicine-list {
    margin-top: 20rpx;
  }
  
  .medicine-item {
    padding: 20rpx;
    border-bottom: 1rpx solid #eee;
  }
  
  .medicine-name {
    font-weight: bold;
    margin-bottom: 10rpx;
  }
  
  .buy-link {
    color: #1976D2;
    text-decoration: underline;
    margin-top: 10rpx;
    display: inline-block;
  }