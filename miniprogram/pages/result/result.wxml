<!-- pages/result/result.wxml -->
<view class="container">
  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text class="back-icon">←</text>
    <text class="back-text">返回</text>
  </view>
  
  <!-- 识别结果卡片 -->
  <view class="result-card">
    <text class="result-title">识别结果</text>
    <view class="disease-info">
      <text class="disease-name">{{result.diseaseName}}</text>
      <text class="confidence">置信度: {{result.confidence * 100 | toFixed(1)}}%</text>
    </view>
    <view class="suggestions">
      <text class="subtitle">症状描述</text>
      <text class="text">{{result.symptoms}}</text>
    </view>
  </view>
  
  <!-- 防治建议卡片 -->
  <view class="suggestion-card">
    <text class="card-title">防治建议</text>
    <view class="suggestion-content">
      <text class="text">{{result.suggestions}}</text>
    </view>
  </view>
  
  <!-- 【修改】推荐用药模块（适配淘宝自动搜索） -->
  <view class="medicine-card">
    <text class="card-title">推荐用药</text>
    <view class="medicine-list">
      <view wx:for="{{result.medicines}}" wx:key="index" class="medicine-item">
        <!-- 直接显示药品名称（AI返回的是字符串数组） -->
        <text class="medicine-name">{{item}}</text>
        <!-- 新增：淘宝购买按钮（传递药品名称而非静态链接） -->
        <button 
          class="buy-btn" 
          data-medicine="{{item}}" 
          bindtap="openBuyLink"
          size="mini"
          type="primary"
          plain
        >
          淘宝购买
        </button>
      </view>
    </view>
    <!-- 空状态提示（无推荐用药时显示） -->
    <view class="empty-tip" wx:if="{{result.medicines.length === 0}}">
      {{result.medicineSuggestion}}
    </view>
  </view>
  
  <!-- 用药建议模块（保持不变） -->
  <view class="suggestion-card">
    <text class="card-title">用药建议</text>
    <view class="suggestion-content">
      <text class="text">{{result.medicineSuggestion}}</text>
    </view>
  </view>
  
  <!-- 预防措施卡片 -->
  <view class="prevention-card">
    <text class="card-title">预防措施</text>
    <view class="prevention-content">
      <text class="text">{{result.prevention}}</text>
    </view>
  </view>

  <!-- 【优化】知识库入口按钮（增加容错和调试样式） -->
  <view class="knowledge-section" style="padding: 20rpx; background-color: #f0f9ff; border-radius: 12rpx; margin: 20rpx 0;">
    <button 
      class="knowledge-btn" 
      bindtap="goDiseaseKnowledge"
      type="primary"
      style="background-color: #00a8e8; color: white; border: none; width: 100%; height: 88rpx; line-height: 88rpx; font-size: 32rpx; border-radius: 12rpx;"
      hover-class="btn-hover"
    >
      查看{{result.diseaseName || '葡萄病害'}}详细知识库
    </button>
  </view>
  
  <!-- 操作按钮（保持不变） -->
  <view class="action-buttons">
    <button 
      class="reidentify-btn" 
      bindtap="reidentify"
      type="default"
    >
      重新识别
    </button>
    <button 
      class="share-btn" 
      open-type="share"
      bindtap="shareResult"
      type="primary"
    >
      分享结果
    </button>
  </view>
  
  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="tip-text">* 本识别结果仅供参考，如有疑问请咨询专业人士</text>
  </view>
</view>