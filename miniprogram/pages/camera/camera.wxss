/* pages/camera/camera.wxss */

.container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background-color: #000;
  }
  
  /* 摄像头预览区域 */
  .camera-container {
    flex: 1;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .camera {
    width: 100%;
    height: 100%;
  }
  
  /* 【新增】未授权时的摄像头占位符样式 */
  .camera-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }
  
  /* 【新增】占位符提示文字样式 */
  .placeholder-text {
    color: #999;
    font-size: 28rpx;
  }
  
  /* 拍照区域指示框 */
  .camera-guide {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600rpx;
    height: 600rpx;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  
  .guide-frame {
    width: 100%;
    height: 100%;
    border: 4rpx solid #4CAF50;
    border-radius: 20rpx;
    position: relative;
  }
  
  .guide-frame::before,
  .guide-frame::after {
    content: '';
    position: absolute;
    width: 40rpx;
    height: 40rpx;
    border: 4rpx solid #4CAF50;
  }
  
  .guide-frame::before {
    top: -10rpx;
    left: -10rpx;
    border-right: none;
    border-bottom: none;
  }
  
  .guide-frame::after {
    bottom: -10rpx;
    right: -10rpx;
    border-left: none;
    border-top: none;
  }
  
  .guide-text {
    position: absolute;
    bottom: -80rpx;
    color: #4CAF50;
    font-size: 28rpx;
    text-align: center;
  }
  
  /* 控制面板 */
.control-panel {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx;
  background-color: #000;
  margin-top: 20rpx;
}

.album-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  background-color: #f0f0f0;
  color: #333;
}

.capture-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  background-color: #f0f0f0;
  color: #333;
}

/* 【新增】拍照按钮禁用状态样式 */
.capture-btn[disabled] {
  background-color: #ddd !important;
  color: #999 !important;
}
  
  /* 预览图片 */
  .preview-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #000;
    display: flex;
    flex-direction: column;
    z-index: 998;
  }
  
  .preview-image {
    flex: 1;
    width: 100%;
    object-fit: contain;
  }
  
  .preview-controls {
    display: flex;
    justify-content: space-around;
    padding: 30rpx;
    background-color: #000;
  }
  
  .retake-btn,
.confirm-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 20rpx;
}
  
  /* 加载动画 */
  .loading-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 999;
  }
  
  .loading-content {
    background-color: rgba(255, 255, 255, 0.9);
    padding: 40rpx;
    border-radius: 20rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .loading-text {
    font-size: 32rpx;
    color: #4CAF50;
    margin-bottom: 20rpx;
  }
  
  .loading-dots {
    display: flex;
    justify-content: center;
  }
  
  .loading-dot {
    font-size: 36rpx;
    color: #4CAF50;
    animation: pulse 1s infinite;
    margin: 0 5rpx;
  }
  
  @keyframes pulse {
    0% { opacity: 0.3; }
    50% { opacity: 1; }
    100% { opacity: 0.3; }
  }
  
  .loading-dot:nth-child(2) {
    animation-delay: 0.2s;
  }
  
  .loading-dot:nth-child(3) {
    animation-delay: 0.4s;
  }