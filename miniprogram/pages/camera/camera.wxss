/* pages/camera/camera.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100%; /* 【核心修正1】明确宽度，避免iOS端宽度计算失效 */
  background-color: #000;
  overflow: hidden; /* 【优化】防止内容溢出 */
}

/* 摄像头预览区域 */
.camera-container {
  flex: 1;
  position: relative;
  width: 100%; /* 【优化】明确宽度，与父容器保持一致 */
  overflow: hidden; /* 【核心修正2】防止原生组件溢出影响布局 */
}

.camera {
  width: 100%;
  height: 100%;
  display: block; /* 【核心修正3】避免inline元素默认间距导致的布局偏移 */
}

/* 【新增】未授权时的摄像头占位符样式 */
.camera-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

/* 【新增】占位符提示文字样式 */
.placeholder-text {
  color: #999;
  font-size: 28rpx;
}

/* 拍照区域指示框 */
.camera-guide {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  height: 600rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 10; /* 【优化】明确层级，确保指示框在摄像头之上 */
}

.guide-frame {
  width: 100%;
  height: 100%;
  border: 4rpx solid #4CAF50;
  border-radius: 20rpx;
  position: relative;
}

.guide-frame::before,
.guide-frame::after {
  content: '';
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #4CAF50;
}

.guide-frame::before {
  top: -10rpx;
  left: -10rpx;
  border-right: none;
  border-bottom: none;
}

.guide-frame::after {
  bottom: -10rpx;
  right: -10rpx;
  border-left: none;
  border-top: none;
}

.guide-text {
  position: absolute;
  bottom: -80rpx;
  color: #4CAF50;
  font-size: 28rpx;
  text-align: center;
}

/* 控制面板 */
.control-panel {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 30rpx; /* 【优化】增加左右内边距，避免按钮贴边 */
  background-color: #000;
  /* 【核心修正4】移除margin-top，避免flex布局中出现多余空白 */
  flex-shrink: 0; /* 【优化】防止控制面板被flex压缩 */
}

.album-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  background-color: #f0f0f0;
  color: #333;
}

.capture-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  background-color: #f0f0f0;
  color: #333;
}

/* 【新增】拍照按钮禁用状态样式 */
.capture-btn[disabled] {
  background-color: #ddd !important;
  color: #999 !important;
}

/* 预览图片 */
.preview-container {
  position: fixed; /* 【核心修正5】改用fixed，确保iOS端全屏覆盖（absolute可能因父容器定位失效） */
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #000;
  display: flex;
  flex-direction: column;
  z-index: 998;
}

.preview-image {
  flex: 1;
  width: 100%;
  object-fit: contain;
}

.preview-controls {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background-color: #000;
  flex-shrink: 0; /* 【优化】防止控制栏被压缩 */
}

.retake-btn,
.confirm-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 20rpx;
}

/* 加载动画 */
.loading-overlay {
  position: fixed; /* 【核心修正5】改用fixed，确保iOS端全屏覆盖 */
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-content {
  background-color: rgba(255, 255, 255, 0.9);
  padding: 40rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-text {
  font-size: 32rpx;
  color: #4CAF50;
  margin-bottom: 20rpx;
}

.loading-dots {
  display: flex;
  justify-content: center;
}

.loading-dot {
  font-size: 36rpx;
  color: #4CAF50;
  animation: pulse 1s infinite;
  margin: 0 5rpx;
}

@keyframes pulse {
  0% { opacity: 0.3; }
  50% { opacity: 1; }
  100% { opacity: 0.3; }
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}