/* pages/camera/camera.wxss */
.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background-color: #f5f5f5;
}

.camera-preview {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

/* 引导框（位置保持不变） */
.guide-overlay {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 2;
  pointer-events: none;
}

.guide-frame {
  width: 80vw;
  height: 55vh;
  position: absolute;
  top: 10vh;
  left: 10vw;
  border: 3rpx solid #4CAF50;
  border-radius: 16rpx;
  background-color: transparent;
}

.guide-text {
  position: absolute;
  top: 67vh;
  left: 0;
  width: 100vw;
  text-align: center;
  font-size: 28rpx;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
}

.auth-page {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 99;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.auth-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.auth-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 60rpx;
}

.auth-btn {
  width: 400rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background-color: #4CAF50;
  color: #fff;
  font-size: 30rpx;
  line-height: 88rpx;
  text-align: center;
}
.auth-btn-active { opacity: 0.8; }

/* ===== 核心修复1：移除半透明背景，完全透明 ===== */
.control-panel {
  width: 100vw;
  position: fixed;
  bottom: 120rpx;
  left: 0;
  z-index: 10;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 30rpx;
  box-sizing: border-box;
  /* 移除半透明背景，完全和相机画面融合 */
  background: transparent;
}

/* ===== 核心修复2：按钮文字绝对居中，放弃flex改用原生兼容方案 ===== */
.album-btn,
.capture-btn {
  width: 300rpx;
  height: 88rpx;
  border-radius: 44rpx;
  /* 核心：line-height和高度完全一致，实现垂直居中 */
  line-height: 88rpx;
  /* 核心：text-align实现水平居中 */
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  /* 防止文字换行 */
  white-space: nowrap;
  flex-shrink: 0;
  box-sizing: border-box;
}

.album-btn {
  background-color: #ffffff;
  color: #333333;
}
.album-btn:active { background-color: #e0e0e0; }

.capture-btn {
  background-color: #4CAF50;
  color: #ffffff;
}
.capture-btn:active { background-color: #388E3C; }

/* 预览弹窗（保持不变） */
.preview-modal {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 999;
  background-color: #000000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 0;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.preview-image {
  width: 90vw;
  max-height: 70vh;
  border-radius: 12rpx;
}

.preview-buttons {
  width: 100vw;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.retake-btn,
.confirm-btn {
  width: 300rpx;
  height: 88rpx;
  border-radius: 44rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  white-space: nowrap;
}

.retake-btn {
  background-color: #ffffff;
  color: #333333;
}
.retake-btn-active { background-color: #e0e0e0; }

.confirm-btn {
  background-color: #4CAF50;
  color: #ffffff;
}
.confirm-btn-active { background-color: #388E3C; }

/* 加载动画（保持不变） */
.loading-overlay {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 9999;
  background-color: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-text {
  font-size: 32rpx;
  color: #ffffff;
  margin-bottom: 30rpx;
}

.loading-dots { display: flex; align-items: center; justify-content: center; }

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ffffff;
  margin: 0 8rpx;
  animation: dotBlink 1.4s infinite ease-in-out both;
}
.loading-dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dotBlink {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.camera-preview {
  width: 100vw;
  height: 100vh;
}