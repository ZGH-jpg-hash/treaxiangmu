<view class="container">
  <camera 
    wx:if="{{isCameraAuthorized}}"
    hidden="{{cameraHidden}}"
    device-position="back"
    flash="auto" 
    class="camera-preview"
    binderror="handleCameraError"
    bindinit="onCameraReady"
    bindready="onCameraReady"
  ></camera>

  <cover-view wx:if="{{isCameraAuthorized && !cameraHidden}}" class="guide-overlay">
    <cover-view class="guide-frame"></cover-view>
    <cover-view class="guide-text">请将葡萄病变部位对准此区域</cover-view>
  </cover-view>

  <view wx:if="{{!isCameraAuthorized}}" class="auth-page">
    <view class="auth-content">
      <text class="auth-title">需要摄像头权限</text>
      <text class="auth-desc">请允许使用摄像头，完成葡萄病害拍摄识别</text>
      <view class="auth-btn" bindtap="applyCameraPermission" hover-class="auth-btn-active">立即授权</view>
    </view>
  </view>

  <cover-view wx:if="{{isCameraAuthorized && !cameraHidden && !previewImage}}" class="control-panel">
    <cover-view class="album-btn" bindtap="chooseImage">从相册选择</cover-view>
    <cover-view class="capture-btn" bindtap="takePhoto">拍照识别</cover-view>
  </cover-view>

  <view wx:if="{{previewImage}}" class="preview-modal">
    <image src="{{previewImage}}" class="preview-image" mode="aspectFit"></image>
    <view class="preview-buttons">
      <view class="retake-btn" bindtap="retakePhoto" hover-class="retake-btn-active">重拍</view>
      <view class="confirm-btn" bindtap="confirmPhoto" hover-class="confirm-btn-active">确认上传</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-content">
      <text class="loading-text">正在识别中...</text>
      <view class="loading-dots">
        <text class="loading-dot">{{loadingDots[0]}}</text>
        <text class="loading-dot">{{loadingDots[1]}}</text>
        <text class="loading-dot">{{loadingDots[2]}}</text>
      </view>
    </view>
  </view>
</view>