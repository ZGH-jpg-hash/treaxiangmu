/* pages/knowledge/knowledge.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 40rpx;
}

/* 搜索栏样式 */
.search-container {
  padding: 20rpx 30rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 48rpx;
  padding: 0 30rpx;
  height: 80rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
}

.clear-btn {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
  margin-left: 10rpx;
}

/* 列表样式 */
.disease-list {
  padding: 20rpx 30rpx;
}

.disease-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.item-hover {
  background-color: #f0f9ff;
  transform: scale(0.98);
  transition: all 0.2s;
}

.disease-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.disease-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.disease-type {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.tag-fungi {
  background-color: #fff3e0;
  color: #f57c00;
}

.tag-health {
  background-color: #e8f5e9;
  color: #4caf50;
}

.disease-alias {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.disease-symptoms {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
  padding-right: 40rpx;
}

.disease-arrow {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #ccc;
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}